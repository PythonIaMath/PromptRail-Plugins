{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/session-start.mjs\"",
            "statusMessage": "Starting PromptRail reasoning router"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/user-prompt-submit.mjs\""
          }
        ]
      }
    ]
  }
}
