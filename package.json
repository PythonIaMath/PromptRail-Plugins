{
  "name": "@promptrail/plugins",
  "version": "1.2.2",
  "description": "Open-source PromptRail reasoning-effort routers for Codex and Claude Code.",
  "type": "module",
  "bin": {
    "plugins": "bin/promptrail.mjs",
    "promptrail": "bin/promptrail.mjs",
    "promptrail-codex-router": "bin/promptrail-codex-router.mjs",
    "promptrail-claude-router": "bin/promptrail-claude-router.mjs"
  },
  "files": [
    ".agents/",
    ".claude-plugin/",
    "bin/",
    "lib/",
    "plugins/",
    "CHANGELOG.md",
    "LICENSE",
    "PRIVACY.md",
    "README.md",
    "SECURITY.md",
    "VERSION"
  ],
  "scripts": {
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "test": "node --test",
    "test:codex": "node --test test/codex",
    "test:claude": "node --test test/claude",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PythonIaMath/PromptRail-Plugins.git"
  },
  "homepage": "https://promptrail.ai",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "promptrail",
    "codex",
    "claude-code",
    "reasoning",
    "effort",
    "routing"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
